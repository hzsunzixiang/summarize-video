# bilibili_tool - Video to PDF pipeline
# ======================================

# Large binary files
*.mp4
*.mp3
audio_parts/
slides/
key_slides/

# Publish outputs (both modes)
publish_tex/*.pdf
publish_tex/*.tex
publish_tex/images/
publish_tex/Makefile
publish_md/*.pdf
publish_md/*.md
publish_md/*.pptx
publish_md/images/
publish_md/Makefile
publish_md/md2pdf.py
publish_md/md2pptx.py

# Whisper intermediate outputs
whisper_part*.txt
full_whisper_transcript.txt

# Office temp files
~$*

# LaTeX auxiliary files
*.aux
*.log
*.out
*.toc
*.fls
*.fdb_latexmk
*.synctex.gz
*.nav
*.snm
*.vrb

# Python cache
__pycache__/
*.pyc
