# ============================================================================
# config.env — Video to PDF Transcript Configuration
#
# Fill in the parameters below, then run:
#   make all
#
# Only URL is required. All other parameters have sensible defaults.
# ============================================================================

# [Required] Video URL (Bilibili or YouTube)
URL = https://www.youtube.com/watch?v=487AjvFW1lk

# [Required] PDF title (shown on the cover page)
TITLE = A Decade (or So) of Fully Homomorphic Encryption

# [Optional] Whisper language: en | zh | auto (default: en)
WHISPER_LANG = en

# [Optional] Audio segment length in seconds (default: 600 = 10 min)
SEGMENT_SEC = 600

# [Optional] Frame extraction interval in seconds (default: 30)
FRAME_INTERVAL = 30

# [Optional] dhash dedup threshold, higher = fewer slides (default: 20)
DEDUP_THRESH = 20

# [Optional] Whisper model directory (default: ~/.summarize/cache/whisper-cpp/models)
WHISPER_MODELS = $(HOME)/.summarize/cache/whisper-cpp/models

# [Optional] yt-dlp format string (default: 720p)
VIDEO_FORMAT = bestvideo[height<=720]+bestaudio/best[height<=720]

# [Optional] Publish mode: tex | md | auto (default: auto)
#   tex   — Use LaTeX/xelatex to compile PDF (best quality, requires mactex)
#   md    — Use Markdown + Python tools to generate PDF/PPTX (no LaTeX needed)
#   auto  — Auto-detect: use tex if xelatex is installed, otherwise fallback to md
PUBLISH_MODE = auto

# [Optional] Translate to Chinese: yes | no | auto (default: auto)
#   yes   — Always translate transcript to Chinese
#   no    — Skip Chinese translation
#   auto  — Let the LLM decide based on WHISPER_LANG (translate if source is not zh)
TRANSLATE_ZH = auto
